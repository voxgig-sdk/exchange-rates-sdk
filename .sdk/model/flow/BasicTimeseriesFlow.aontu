# BasicTimeseriesFlow

main: kit: flow: BasicTimeseriesFlow:
{
  entity: "timeseries",
  kind: "basic",
  name: "BasicTimeseriesFlow",
  step: [
    {
      input: {
        ref: "timeseries_ref01",
        srcdatavar: "timeseries_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-timeseries_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicTimeseriesFlow"
}